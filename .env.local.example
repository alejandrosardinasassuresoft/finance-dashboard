# Copy this file to .env.local and fill in your values.

# ── AI Insights ──────────────────────────────────────────────────────────────
# OpenAI API key — required for GPT-4o financial insights
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Optional: override the default SQLite path (./finance.db locally, /tmp/finance.db on Vercel)
# DATABASE_PATH=/absolute/path/to/finance.db
